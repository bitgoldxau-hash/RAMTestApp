<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#0F0F1A">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🧪 RAM Test App"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tv_required"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Required: 10 GB RAM"
        android:textColor="#6C63FF"
        android:textSize="15sp"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:id="@+id/tv_ram_info"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Checking RAM..."
        android:textColor="#AAAAAA"
        android:textSize="14sp"
        android:lineSpacingMultiplier="1.6"
        android:gravity="center"
        android:background="#16162A"
        android:padding="16dp"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:id="@+id/tv_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Checking..."
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="If blocked:\n1. Open RAM Booster Pro\n2. Boost RAM to 10 GB\n3. Come back to this app"
        android:textColor="#7C7C9E"
        android:textSize="13sp"
        android:lineSpacingMultiplier="1.5"
        android:gravity="center"/>

</LinearLayout>
